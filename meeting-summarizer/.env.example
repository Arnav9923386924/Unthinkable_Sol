# OpenRouter API key — used for BOTH Whisper transcription AND LLM summarization
OPENROUTER_API_KEY=sk-or-your-openrouter-api-key-here

# (Optional) Whisper model for transcription via OpenRouter
# Default: openai/whisper-large-v3
# OPENROUTER_WHISPER_MODEL=openai/whisper-large-v3

# (Optional) LLM model for summarization via OpenRouter
# Default: openai/gpt-4o-mini
# Good alternatives: anthropic/claude-3.5-haiku, google/gemini-flash-1.5
# OPENROUTER_MODEL=openai/gpt-4o-mini
